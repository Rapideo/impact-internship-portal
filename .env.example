# Supabase
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<anon key>
SUPABASE_SERVICE_ROLE_KEY=<service role key>

# Database (direct connection for migrations + admin scripts)
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# Database (pooled connection for runtime)
DATABASE_POOL_URL=postgresql://postgres.<ref>:<password>@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Email
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM=onboarding@resend.dev

# App
APP_URL=http://localhost:5173

# Used to sign the anonymous intern identity cookie (HMAC-SHA256).
# Generate via: openssl rand -hex 32
SESSION_SECRET=<at least 32 random bytes>

