{
  "name": "impact-internship-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "IMPACT Internship Assessment Portal — production rebuild scaffolding (sub-project 0 baseline).",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "react-router dev",
    "build": "react-router build",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run --project unit --project dom",
    "test:watch": "vitest --project unit --project dom",
    "test:rls": "vitest run --project rls",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx db/seed.ts",
    "db:seed:demo": "tsx db/seed-demo.ts",
    "db:seed-prod": "tsx db/seed-prod.ts",
    "db:apply-policies": "tsx db/apply-policies.ts",
    "admin:create": "tsx scripts/create-admin.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.css": [
      "prettier --write"
    ],
    "*.md": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.61.0",
    "@react-router/dev": "^7.15.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.18",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitest/ui": "^3.2.4",
    "dotenv": "^16.6.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.4.2",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@netlify/vite-plugin-react-router": "^3.1.1",
    "@react-router/node": "^7.15.0",
    "@react-router/serve": "^7.15.0",
    "@sentry/react-router": "^10.59.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.105.4",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.43",
    "postgres": "^3.4.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.15.0",
    "resend": "^4.8.0"
  }
}
